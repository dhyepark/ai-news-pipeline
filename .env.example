# 로컬 테스트용. 실제 값을 채운 뒤 .env 로 복사하세요. (.env는 커밋 금지)
# cp .env.example .env

# Google AI Studio(https://aistudio.google.com/apikey)에서 무료 발급
GEMINI_API_KEY=AIxxxxxxxx

# Slack 앱 > Incoming Webhooks에서 발급한 URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# (선택) 기본값을 바꾸고 싶을 때만
# GEMINI_MODEL=gemini-2.5-flash
# LOOKBACK_HOURS=24
# MAX_ITEMS=8